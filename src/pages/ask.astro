---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";
---

<Layout title={`Ask Anonymously | Am I Normal? | ${SITE.title}`}>
  <Header activeNav="about" />
  <Main pageTitle="Ask Anonymously" pageDesc="Submit your mental health questions. Your identity is 100% protected.">
    
    <div class="mt-12 max-w-2xl mx-auto">
        <div class="prose dark:prose-invert mb-12">
            <p>Ever wondered if what you're feeling is "normal"? You're not alone. Submit your question below. We select the most common and impactful questions to answer publicly on our <a href="/community-qa">Community Board</a>.</p>
            <ul>
                <li><strong>Private & Confidential</strong>: Your identity is protected and never shared.</li>
                <li><strong>Professional</strong>: Every answer is written by a certified counselor.</li>
                <li><strong>Safe</strong>: This is a judgment-free space.</li>
            </ul>
        </div>

        <div class="space-y-6 bg-muted/20 p-8 rounded-[2rem] border border-muted">
            <div>
                <label for="question" class="block text-sm font-bold uppercase tracking-widest mb-2 opacity-70">Your Question</label>
                <textarea 
                    id="question" 
                    name="question" 
                    required 
                    placeholder="e.g., Is it normal to feel lonely even when I'm with friends?"
                    class="w-full h-40 bg-background border border-muted rounded-2xl p-4 focus:border-accent outline-none transition-all resize-none"
                ></textarea>
            </div>

            <div>
                <label for="context" class="block text-sm font-bold uppercase tracking-widest mb-2 opacity-70">A bit more context (Optional)</label>
                <textarea 
                    id="context" 
                    name="context" 
                    placeholder="Provide some details if you'd like a more specific perspective..."
                    class="w-full h-32 bg-background border border-muted rounded-2xl p-4 focus:border-accent outline-none transition-all resize-none"
                ></textarea>
            </div>

            <button id="submit-button" class="w-full py-4 bg-accent text-white font-bold rounded-full hover:scale-[1.02] active:scale-[0.98] transition-all shadow-lg shadow-accent/20">
                Send Question via Email
            </button>
            <p class="text-[10px] text-center opacity-40 uppercase font-bold tracking-tighter">Clicking submit will open your email client. By sending, you agree that your question (anonymized) may be published.</p>
        </div>
    </div>

    <script is:inline>
        const submitBtn = document.getElementById("submit-button");
        const questionInput = document.getElementById("question");
        const contextInput = document.getElementById("context");

        submitBtn?.addEventListener("click", () => {
            const question = questionInput?.value;
            const context = contextInput?.value;

            if (!question) {
                alert("Please enter your question first.");
                return;
            }

            const subject = encodeURIComponent("Community Board Question");
            const body = encodeURIComponent(`Question:\n${question}\n\nContext:\n${context || "No context provided."}`);
            
            window.location.href = `mailto:support@iamsukhpreet.com?subject=${subject}&body=${body}`;
        });
    </script>

  </Main>
  <Footer />
</Layout>
