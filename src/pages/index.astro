---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import TrustBar from "@/components/TrustBar.astro";
import Testimonials from "@/components/Testimonials.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import avatarImage from "@/assets/img/simple.jpg";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border flex flex-col-reverse sm:flex-row items-center justify-between gap-6"]}>
      <div class="flex-1">
        <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
          Feeling stressed, anxious or overwhelmed?
        </h1>
        <p class="text-lg opacity-90 mb-8">
          Talk to a certified psychologist in a safe, confidential space.
        </p>
        
        <div class="flex flex-wrap gap-4 mb-8">
          <a 
            href="https://booking.iamsukhpreet.com/sukhpreet-kaur/book-a-session" 
            target="_blank" 
            rel="noopener noreferrer"
            class="px-6 py-3 bg-accent text-white font-bold rounded-lg transition-transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-accent/20"
          >
            Book a Session
          </a>
          <a 
            href="https://wa.me/917568592988" 
            target="_blank" 
            rel="noopener noreferrer"
            class="px-6 py-3 bg-[#25D366] text-white font-bold rounded-lg transition-transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-green-500/20"
          >
            Chat on WhatsApp
          </a>
        </div>

        {
          // only display if at least one social link is enabled
          SOCIALS.length > 0 && (
            <div class="mt-4 flex max-sm:flex-col sm:items-center">
              <div class="me-2 mb-1 whitespace-nowrap sm:mb-0 font-semibold text-accent">Follow me:</div>
              <Socials />
            </div>
          )
        }
      </div>

      <div class="flex-none">
        <Image 
          src={avatarImage} 
          alt="Sukhpreet Kaur - Professional Psychological Counselor" 
          width={180} 
          height={180} 
          class="rounded-full border-4 border-accent/20 shadow-lg object-cover"
          loading="eager"
        />
      </div>
    </section>

    <TrustBar />

    <Testimonials />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Resources</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Resources
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
