---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import TrustBar from "@/components/TrustBar.astro";
import Testimonials from "@/components/Testimonials.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import avatarImage from "@/assets/img/simple.jpg";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout 
  title="Online Psychological Counseling & Therapy | Sukhpreet Kaur"
  description="Professional online psychological counseling for anxiety, depression, and stress. Certified psychologist Sukhpreet Kaur provides a safe, confidential space for your mental well-being."
>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border flex flex-col-reverse sm:flex-row items-center justify-between gap-6"]}>
      <div class="flex-1">
        <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
          Feeling stressed, anxious or overwhelmed?
        </h1>
        <p class="text-lg opacity-90 mb-8">
          Talk to a certified psychologist in a safe, confidential space.
        </p>
        
        <div class="flex flex-wrap gap-4 mb-8">
          <a 
            href="https://hellosukh.com/sukhpreet-kaur/book-a-session" 
            target="_blank" 
            rel="noopener noreferrer"
            class="px-6 py-3 bg-accent text-white font-bold rounded-lg transition-transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-accent/20"
          >
            Book a Session
          </a>
          <a 
            href="https://wa.me/917568592988" 
            target="_blank" 
            rel="noopener noreferrer"
            class="px-6 py-3 bg-[#25D366] text-white font-bold rounded-lg transition-transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-green-500/20"
          >
            Chat on WhatsApp
          </a>
        </div>

        {
          // only display if at least one social link is enabled
          SOCIALS.length > 0 && (
            <div class="mt-4 flex max-sm:flex-col sm:items-center">
              <div class="me-2 mb-1 whitespace-nowrap sm:mb-0 font-semibold text-accent">Follow me:</div>
              <Socials />
            </div>
          )
        }
      </div>

      <div class="flex-none">
        <Image 
          src={avatarImage} 
          alt="Sukhpreet Kaur - Professional Psychological Counselor" 
          width={180} 
          height={180} 
          class="rounded-full border-4 border-accent/20 shadow-lg object-cover"
          loading="eager"
        />
      </div>
    </section>

    <TrustBar />

    <!-- Self-Discovery & Relief Section -->
    <section id="discovery" class="pt-24 pb-12 border-b border-border">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Discovery & Relief Tools</h2>
        <p class="opacity-80 max-w-2xl mx-auto">Interactive tools and educational resources to help you understand your mental well-being.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/quizzes" class="p-8 border border-muted rounded-[2rem] bg-muted/5 hover:border-accent hover:shadow-lg transition-all text-center group">
          <span class="text-4xl block mb-4 group-hover:scale-110 transition-transform">🛡️</span>
          <h3 class="font-bold text-xl mb-2">Wellness Quizzes</h3>
          <p class="text-sm opacity-70">Discover your coping style and stress levels.</p>
        </a>
        <a href="/glossary" class="p-8 border border-muted rounded-[2rem] bg-muted/5 hover:border-accent hover:shadow-lg transition-all text-center group">
          <span class="text-4xl block mb-4 group-hover:scale-110 transition-transform">📖</span>
          <h3 class="font-bold text-xl mb-2">Psychology Glossary</h3>
          <p class="text-sm opacity-70">A plain-English guide to mental health terms.</p>
        </a>
        <a href="/community-qa" class="p-8 border border-muted rounded-[2rem] bg-muted/5 hover:border-accent hover:shadow-lg transition-all text-center group">
          <span class="text-4xl block mb-4 group-hover:scale-110 transition-transform">❓</span>
          <h3 class="font-bold text-xl mb-2">Am I Normal?</h3>
          <p class="text-sm opacity-70">Anonymous questions answered by experts.</p>
        </a>
        <a href="/instant-relief" class="p-8 border border-muted rounded-[2rem] bg-muted/5 hover:border-accent hover:shadow-lg transition-all text-center group">
          <span class="text-4xl block mb-4 group-hover:scale-110 transition-transform">🎮</span>
          <h3 class="font-bold text-xl mb-2">Instant Relief</h3>
          <p class="text-sm opacity-70">Interactive games for quick stress relief.</p>
        </a>
        <a href="/panic-relief" class="p-8 border border-red-500/20 rounded-[2rem] bg-red-500/5 hover:border-red-500 hover:shadow-lg transition-all text-center group">
          <span class="text-4xl block mb-4 group-hover:scale-110 transition-transform">🚨</span>
          <h3 class="font-bold text-xl mb-2 text-red-500">Panic Relief</h3>
          <p class="text-sm opacity-70">Immediate grounding tools for anxiety.</p>
        </a>
      </div>
    </section>

    <Testimonials />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Resources</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Resources
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
