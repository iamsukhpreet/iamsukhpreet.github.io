---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import BilingualToggle from "@/components/BilingualToggle.astro";
import CrisisSupport from "@/components/CrisisSupport.astro";
import { SITE } from "@/config";
import calmImg from "@/assets/img/calm.jpg";

const toolkits = [
  {
    id: "breathing",
    number: "1",
    title: "Breath-Based Reset",
    subtitle: "Fastest Calm Tool",
    emoji: "🌿",
    whenToUse: ["Anxiety spike", "Overthinking", "High Stress"],
    techniqueName: "Box Breathing (2–5 minutes)",
    techniqueSteps: [
      "Inhale for 4 seconds",
      "Hold for 4 seconds",
      "Exhale for 4 seconds",
      "Hold for 4 seconds"
    ],
    tools: ["Insight Timer", "Breathwrk"],
    keyIdea: "Your breath is the fastest way to 'hack' your nervous system."
  },
  {
    id: "meditation",
    number: "2",
    title: "Guided Meditation",
    subtitle: "Beginner Friendly",
    emoji: "🧘",
    whenToUse: ["Daily routine", "Trouble focusing", "Emotional overwhelm"],
    techniqueName: "How to start (10 mins daily)",
    techniqueSteps: [
      "Sit comfortably",
      "Play a guided session",
      "Just follow instructions (no need to 'do it perfectly')"
    ],
    tools: ["Headspace", "Calm", "Waking Up"],
    keyIdea: "Consistency > perfection. Even 5 minutes daily works."
  },
  {
    id: "journaling",
    number: "3",
    title: "Thought Dump / Journaling",
    subtitle: "Clarity Tool",
    emoji: "✍️",
    whenToUse: ["Racing thoughts", "Stress before sleep", "Decision-making"],
    techniqueName: "Method: Brain Dump (5–10 mins)",
    techniqueSteps: [
      "Write everything in your mind",
      "No structure, no editing",
      "Don't reread immediately"
    ],
    tools: ["Day One", "Notion"],
    keyIdea: "Clarity comes from getting thoughts out of your head."
  },
  {
    id: "movement",
    number: "4",
    title: "Mindful Movement",
    subtitle: "Shift Mental State",
    emoji: "🚶",
    whenToUse: ["Feeling stuck", "Low energy", "Long screen time"],
    techniqueName: "Activities",
    techniqueSteps: [
      "10–20 min walk (no phone)",
      "Light stretching or yoga",
      "Focus on sounds & textures"
    ],
    tools: ["Nike Training Club", "Down Dog"],
    keyIdea: "Movement shifts mental state faster than thinking."
  }
];
---

<Layout title={`Mental Wellness Toolkit | ${SITE.title}`}>
  <Header activeNav="meditation" />
  
  <div class="relative w-full h-[300px] overflow-hidden">
    <Image 
        src={calmImg} 
        alt="Calm background" 
        class="w-full h-full object-cover opacity-60 grayscale-[0.2]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-background to-transparent"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-4">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight drop-shadow-md">
            Mindfulness Hub
        </h1>
        <p class="mt-4 text-lg md:text-xl opacity-90 max-w-2xl">
            Interactive tools and practical techniques for your daily mental well-being.
        </p>
    </div>
  </div>

  <Main pageTitle="Mindfulness Toolkit" pageDesc="Interactive tools and practical techniques for your daily mental well-being.">
    <BilingualToggle />

    <div class="mt-12 space-y-24">
      
      <!-- Interactive Section: Live Breathing Guide -->
      <section id="interactive-breathing" class="bg-accent/5 p-8 md:p-12 rounded-[2.5rem] border border-accent/20 text-center scroll-mt-24">
        <div class="max-w-md mx-auto">
            <h2 class="text-3xl font-bold mb-2">Live Box Breathing</h2>
            <p class="text-sm opacity-70 mb-8">Follow the expanding circle to sync your breath.</p>
            
            <!-- The Breathing Circle -->
            <div class="relative size-64 mx-auto mb-8 flex items-center justify-center">
                <div id="breathing-circle" class="absolute size-32 bg-accent rounded-full opacity-30 transition-all duration-[4000ms] ease-in-out scale-100"></div>
                <div class="relative z-10 text-2xl font-bold text-accent" id="breathing-text">Inhale</div>
            </div>

            <div class="grid grid-cols-4 gap-2 mb-8">
                <div class="breath-indicator active" data-step="0">In</div>
                <div class="breath-indicator" data-step="1">Hold</div>
                <div class="breath-indicator" data-step="2">Out</div>
                <div class="breath-indicator" data-step="3">Hold</div>
            </div>

            <button id="start-breathing" class="px-8 py-3 bg-accent text-white font-bold rounded-full hover:scale-105 active:scale-95 transition-transform shadow-lg shadow-accent/20">
                Start Activity
            </button>
        </div>
      </section>

      <!-- Interactive Section: Mood Check-in -->
      <section id="mood-check" class="not-prose">
        <h2 class="text-3xl font-bold text-center mb-12">How are you feeling right now?</h2>
        <div class="flex flex-wrap justify-center gap-4">
            <button class="mood-btn" data-mood="anxious">🌪️ Anxious</button>
            <button class="mood-btn" data-mood="overwhelmed">🌊 Overwhelmed</button>
            <button class="mood-btn" data-mood="distracted">🐝 Distracted</button>
            <button class="mood-btn" data-mood="tired">🔋 Low Energy</button>
            <button class="mood-btn" data-mood="calm">☁️ Calm</button>
        </div>
        
        <div id="mood-recommendation" class="mt-8 max-w-2xl mx-auto p-6 bg-muted/20 rounded-2xl border border-muted hidden animate-fade-in text-center">
            <p id="rec-text" class="text-lg font-medium italic"></p>
            <button id="close-rec" class="mt-4 text-xs font-bold text-accent uppercase tracking-widest">Done</button>
        </div>
      </section>

      <!-- Toolkit Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 not-prose">
        {toolkits.map(tool => (
          <div id={tool.id} class="reveal-on-scroll group border border-muted p-8 rounded-3xl bg-muted/10 hover:bg-muted/30 hover:-translate-y-2 transition-all flex flex-col h-full shadow-sm">
            <div class="flex items-center gap-4 mb-8">
              <span class="text-5xl group-hover:scale-110 transition-transform">{tool.emoji}</span>
              <div>
                <h3 class="text-2xl font-bold text-accent">{tool.number}. {tool.title}</h3>
                <p class="text-xs uppercase tracking-widest font-bold opacity-60">{tool.subtitle}</p>
              </div>
            </div>

            <div class="mb-8">
              <p class="text-xs font-bold uppercase mb-3 text-accent/80 tracking-wider">🧩 When to use</p>
              <ul class="flex flex-wrap gap-2">
                {tool.whenToUse.map(trigger => (
                  <li class="text-[10px] bg-background border border-muted px-3 py-1.5 rounded-full font-medium">{trigger}</li>
                ))}
              </ul>
            </div>
            
            <div class="bg-background/40 backdrop-blur-sm p-6 rounded-2xl mb-8 flex-grow border border-muted/30">
              <p class="font-bold text-sm mb-4 flex items-center gap-2">
                <span class="size-2 bg-accent rounded-full"></span>
                {tool.techniqueName}
              </p>
              <ul class="space-y-3">
                {tool.techniqueSteps.map((step, index) => (
                  <li class="text-sm flex gap-4 opacity-90">
                    <span class="text-accent/40 font-black italic">{index + 1}</span>
                    <span>{step}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="flex flex-col gap-4">
              <div class="pt-6 border-t border-muted/50">
                <p class="text-[10px] font-bold uppercase mb-2 opacity-50 tracking-widest text-center">💡 Core Insight</p>
                <p class="text-sm italic opacity-90 leading-relaxed text-center px-4">
                  {tool.keyIdea}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

    <CrisisSupport />
  </Main>
  <Footer />
</Layout>

<style>
    .mood-btn {
        @apply px-6 py-3 rounded-full bg-muted/20 border border-muted hover:border-accent hover:text-accent transition-all font-medium;
    }
    .mood-btn.active {
        @apply bg-accent text-white border-accent shadow-lg shadow-accent/20;
    }
    .breath-indicator {
        @apply text-[10px] uppercase font-bold py-1 border-b-2 border-muted opacity-40 transition-all;
    }
    .breath-indicator.active {
        @apply border-accent opacity-100 scale-110;
    }

    @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
        animation: fade-in 0.4s ease-out forwards;
    }
</style>

<script is:inline>
    // --- Live Breathing Tool Logic ---
    let breathingInterval;
    let currentStep = 0;
    const steps = [
        { text: "Inhale", scale: "scale-[2.5]", opacity: "opacity-60" },
        { text: "Hold", scale: "scale-[2.5]", opacity: "opacity-60" },
        { text: "Exhale", scale: "scale-100", opacity: "opacity-30" },
        { text: "Hold", scale: "scale-100", opacity: "opacity-30" }
    ];

    const circle = document.getElementById('breathing-circle');
    const bText = document.getElementById('breathing-text');
    const startBtn = document.getElementById('start-breathing');
    const indicators = document.querySelectorAll('.breath-indicator');

    function runBreathStep() {
        const step = steps[currentStep];
        
        // Update UI
        circle.className = `absolute size-32 bg-accent rounded-full transition-all duration-[4000ms] ease-in-out ${step.scale} ${step.opacity}`;
        bText.textContent = step.text;
        
        indicators.forEach((ind, i) => {
            ind.classList.toggle('active', i === currentStep);
        });

        currentStep = (currentStep + 1) % 4;
    }

    startBtn.addEventListener('click', () => {
        if (breathingInterval) {
            clearInterval(breathingInterval);
            breathingInterval = null;
            startBtn.textContent = "Start Activity";
            bText.textContent = "Ready?";
            currentStep = 0;
        } else {
            startBtn.textContent = "Stop Activity";
            runBreathStep();
            breathingInterval = setInterval(runBreathStep, 4000);
        }
    });

    // --- Mood Tracker Logic ---
    const moodBtns = document.querySelectorAll('.mood-btn');
    const moodRec = document.getElementById('mood-recommendation');
    const recText = document.getElementById('rec-text');
    const closeRec = document.getElementById('close-rec');

    const recs = {
        anxious: "Try the Box Breathing activity above for 2 minutes to settle your nervous system.",
        overwhelmed: "A 5-minute 'Thought Dump' can help you clear the clutter. See Tool #3.",
        distracted: "The Grounding (5-4-3-2-1) technique can bring your focus back to now.",
        tired: "A 10-minute mindful walk (no phone) is the fastest way to reset energy.",
        calm: "Beautiful! Use this time for a 10-minute meditation to build your emotional baseline."
    };

    moodBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const mood = btn.dataset.mood;
            recText.textContent = recs[mood];
            moodRec.classList.remove('hidden');
            
            // Scroll to the recommended tool if it exists
            if (mood === 'anxious') window.scrollTo({ top: document.getElementById('interactive-breathing').offsetTop - 100, behavior: 'smooth' });
        });
    });

    closeRec.addEventListener('click', () => moodRec.classList.add('hidden'));

    // --- Reveal on Scroll ---
    const observerOptions = { threshold: 0.1 };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-in');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
</script>
