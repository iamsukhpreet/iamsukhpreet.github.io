---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import BilingualToggle from "@/components/BilingualToggle.astro";
import CrisisSupport from "@/components/CrisisSupport.astro";
import { SITE } from "@/config";

const toolkits = [
  {
    number: "1",
    title: "Breath-Based Reset",
    subtitle: "Fastest Calm Tool",
    emoji: "🌿",
    whenToUse: ["Anxiety spike", "Overthinking", "Before an important meeting"],
    techniqueName: "Box Breathing (2–5 minutes)",
    techniqueSteps: [
      "Inhale for 4 seconds",
      "Hold for 4 seconds",
      "Exhale for 4 seconds",
      "Hold for 4 seconds",
      "Repeat 5–10 cycles"
    ],
    tools: ["Insight Timer", "Breathwrk"],
    keyIdea: "Your breath is the fastest way to 'hack' your nervous system."
  },
  {
    number: "2",
    title: "Guided Meditation",
    subtitle: "Beginner Friendly",
    emoji: "🧘",
    whenToUse: ["Daily routine", "Trouble focusing", "Emotional overwhelm"],
    techniqueName: "How to start (10 mins daily)",
    techniqueSteps: [
      "Sit comfortably",
      "Play a guided session",
      "Just follow instructions (no need to 'do it perfectly')"
    ],
    tools: ["Headspace", "Calm", "Waking Up"],
    keyIdea: "Consistency > perfection. Even 5 minutes daily works."
  },
  {
    number: "3",
    title: "Thought Dump / Journaling",
    subtitle: "Clarity Tool",
    emoji: "✍️",
    whenToUse: ["Racing thoughts", "Stress before sleep", "Confusion or decision-making"],
    techniqueName: "Method: Brain Dump (5–10 mins)",
    techniqueSteps: [
      "Write everything in your mind",
      "No structure, no editing",
      "Don't reread immediately"
    ],
    tools: ["Day One", "Notion"],
    keyIdea: "Clarity comes from getting thoughts out of your head."
  },
  {
    number: "4",
    title: "Mindful Movement",
    subtitle: "Shift Mental State",
    emoji: "🚶",
    whenToUse: ["Feeling stuck or low energy", "Mild anxiety", "Long screen time"],
    techniqueName: "Activities",
    techniqueSteps: [
      "10–20 min walk (no phone)",
      "Light stretching or yoga",
      "Focus on surroundings (sounds, textures)"
    ],
    tools: ["Nike Training Club", "Down Dog"],
    keyIdea: "Movement shifts mental state faster than thinking."
  },
  {
    number: "5",
    title: "Sleep Reset Routine",
    subtitle: "Better Recovery",
    emoji: "😴",
    whenToUse: ["Poor sleep", "Overthinking at night", "Burnout"],
    techniqueName: "Routine (30 mins before sleep)",
    techniqueSteps: [
      "No screens",
      "Dim lights",
      "Light reading or meditation",
      "Same sleep time daily"
    ],
    tools: ["Sleep Cycle", "Noisli"],
    keyIdea: "Mental health improves dramatically with good sleep."
  },
  {
    number: "6",
    title: "Cognitive Reframing",
    subtitle: "Advanced but Powerful",
    emoji: "🧠",
    whenToUse: ["Negative self-talk", "Anxiety loops", "Fear-based thinking"],
    techniqueName: "Method",
    techniqueSteps: [
      "Identify: 'I’ll fail this'",
      "Challenge: 'What evidence supports this?'",
      "Replace: 'I’ve prepared well; I’ll try my best'"
    ],
    tools: ["CBT Thought Diary", "Woebot"],
    keyIdea: "Thoughts are not facts—they’re interpretations."
  }
];

const decisionMatrix = [
  { situation: "Immediate stress", tool: "Breathing" },
  { situation: "Daily stability", tool: "Meditation" },
  { situation: "Overthinking", tool: "Journaling" },
  { situation: "Low mood", tool: "Movement" },
  { situation: "Sleep issues", tool: "Sleep routine" },
  { situation: "Negative thinking", tool: "CBT reframing" },
  { situation: "Deep issues", tool: "Therapy" }
];
---

<Layout title={`Mental Wellness Toolkit | ${SITE.title}`}>
  <Header activeNav="meditation" />
  <Main pageTitle="🧠 Mental Wellness Toolkit" pageDesc="A practical guide to meditation, calming techniques, and daily mental health tools.">
    <BilingualToggle />

    <div class="prose dark:prose-invert max-w-none mt-8">
      <p class="text-lg opacity-90 italic border-l-4 border-accent pl-4">
        "Mental health isn’t one big solution—it’s small tools used consistently."
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 not-prose mt-12">
        {toolkits.map(tool => (
          <div class="group border border-muted p-6 rounded-2xl bg-muted/20 hover:bg-muted/30 transition-all flex flex-col h-full shadow-sm">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-4xl">{tool.emoji}</span>
              <div>
                <h3 class="text-xl font-bold text-accent">{tool.number}. {tool.title}</h3>
                <p class="text-xs uppercase tracking-widest font-semibold opacity-70">{tool.subtitle}</p>
              </div>
            </div>

            <div class="mb-6">
              <p class="text-xs font-bold uppercase mb-2 text-accent/80">🧩 When to use</p>
              <ul class="flex flex-wrap gap-2">
                {tool.whenToUse.map(trigger => (
                  <li class="text-[10px] bg-background border border-muted px-2 py-1 rounded-md">{trigger}</li>
                ))}
              </ul>
            </div>
            
            <div class="bg-background/50 p-4 rounded-xl mb-6 flex-grow">
              <p class="font-bold text-sm mb-3">🛠️ {tool.techniqueName}</p>
              <ul class="space-y-2">
                {tool.techniqueSteps.map((step, index) => (
                  <li class="text-sm flex gap-3">
                    <span class="text-accent/50 font-bold">{index + 1}.</span>
                    <span>{step}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="flex flex-col gap-4">
              <div>
                <p class="text-[10px] font-bold uppercase mb-2 opacity-60">🔧 Recommended Tools</p>
                <p class="text-xs">{tool.tools.join(" • ")}</p>
              </div>
              <div class="pt-4 border-t border-muted/50">
                <p class="text-xs italic opacity-80">
                  <strong>💡 Key idea:</strong> {tool.keyIdea}
                </p>
              </div>
            </div>
          </div>
        ))}

        {/* Toolkit 7: Human Support */}
        <div class="group border border-accent/30 p-6 rounded-2xl bg-accent/5 hover:bg-accent/10 transition-all flex flex-col h-full shadow-sm">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-4xl">🧩</span>
              <div>
                <h3 class="text-xl font-bold text-accent">7. Human Support</h3>
                <p class="text-xs uppercase tracking-widest font-semibold opacity-70">When you need more</p>
              </div>
            </div>

            <div class="mb-6">
              <p class="text-xs font-bold uppercase mb-2 text-accent/80">🧩 When to use</p>
              <ul class="flex flex-wrap gap-2">
                <li class="text-[10px] bg-background border border-muted px-2 py-1 rounded-md">Persistent anxiety or sadness</li>
                <li class="text-[10px] bg-background border border-muted px-2 py-1 rounded-md">Relationship issues</li>
                <li class="text-[10px] bg-background border border-muted px-2 py-1 rounded-md">Trauma or burnout</li>
              </ul>
            </div>
            
            <div class="bg-background/50 p-4 rounded-xl mb-6 flex-grow">
              <p class="font-bold text-sm mb-3">🛠️ Options</p>
              <ul class="space-y-2">
                <li class="text-sm flex gap-3">• 1:1 Professional Counselling</li>
                <li class="text-sm flex gap-3">• Group therapy sessions</li>
                <li class="text-sm flex gap-3">• Specialized online therapy</li>
              </ul>
            </div>

            <div class="pt-4 border-t border-accent/20">
                <a href="/booking" class="text-xs font-bold text-accent underline underline-offset-4">
                  Book a session with Sukhpreet Kaur →
                </a>
            </div>
          </div>
      </div>

      <h2 class="mt-20 flex items-center gap-3">
        <span class="text-2xl">🧭</span> How to Choose the Right Tool
      </h2>
      <div class="overflow-x-auto mt-8">
        <table class="w-full text-left border-collapse border border-muted rounded-xl overflow-hidden">
          <thead class="bg-muted/30">
            <tr>
              <th class="p-4 border border-muted font-bold">Situation</th>
              <th class="p-4 border border-muted font-bold text-accent">Best Tool</th>
            </tr>
          </thead>
          <tbody>
            {decisionMatrix.map(item => (
              <tr class="hover:bg-muted/10 transition-colors">
                <td class="p-4 border border-muted">{item.situation}</td>
                <td class="p-4 border border-muted font-semibold">{item.tool}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-20 bg-accent/5 p-8 rounded-3xl border border-accent/20">
        <h2 class="mt-0 flex items-center gap-3">
            <span class="text-2xl">⚡</span> Suggested Daily Routine
        </h2>
        <p class="opacity-80">A simple and realistic approach to maintaining stability throughout the day:</p>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8 not-prose">
            <div class="bg-background p-4 rounded-xl border border-muted shadow-sm">
                <p class="text-[10px] font-bold text-accent uppercase tracking-widest mb-1">Morning</p>
                <p class="text-sm font-semibold">5 min breathing</p>
            </div>
            <div class="bg-background p-4 rounded-xl border border-muted shadow-sm">
                <p class="text-[10px] font-bold text-accent uppercase tracking-widest mb-1">Afternoon</p>
                <p class="text-sm font-semibold">10 min walk</p>
            </div>
            <div class="bg-background p-4 rounded-xl border border-muted shadow-sm">
                <p class="text-[10px] font-bold text-accent uppercase tracking-widest mb-1">Evening</p>
                <p class="text-sm font-semibold">10 min meditation</p>
            </div>
            <div class="bg-background p-4 rounded-xl border border-muted shadow-sm">
                <p class="text-[10px] font-bold text-accent uppercase tracking-widest mb-1">Night</p>
                <p class="text-sm font-semibold">5 min journaling</p>
            </div>
        </div>
      </div>
    </div>

    <CrisisSupport />
  </Main>
  <Footer />
</Layout>
