---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import { SITE } from "@/config";

const bookingOptions = [
  {
    title: "Free Discovery Call",
    description: "A brief 15-minute introductory call to discuss your needs and how counseling can help you.",
    link: "https://booking.iamsukhpreet.com/sukhpreet-kaur/discovery-call",
    label: "Schedule Free Call",
    color: "bg-teal-600",
  },
  {
    title: "Full Counseling Session",
    description: "A comprehensive 60-minute therapeutic session tailored to your specific mental health goals.",
    link: "https://booking.iamsukhpreet.com/sukhpreet-kaur/book-a-session",
    label: "Book Full Session",
    color: "bg-blue-600",
  }
];
---

<Layout title={`Book a Session | ${SITE.title}`}>
  <Header activeNav="booking" />
  <Main pageTitle="Book a Session" pageDesc="Choose the session type that best fits your needs.">
    
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
      {bookingOptions.map(option => (
        <div class="border border-muted p-8 rounded-xl bg-muted/20 flex flex-col items-center text-center shadow-sm hover:shadow-md transition-shadow">
          <h2 class="text-2xl font-bold text-accent mb-4">{option.title}</h2>
          <p class="mb-8 opacity-90 leading-relaxed">
            {option.description}
          </p>
          <a 
            href={option.link} 
            target="_blank" 
            rel="noopener noreferrer"
            class={`mt-auto w-full py-3 px-6 text-white font-bold rounded-lg transition-transform hover:scale-[1.02] active:scale-[0.98] ${option.color}`}
          >
            {option.label}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-16 prose dark:prose-invert max-w-none text-center">
      <h3>Need immediate assistance?</h3>
      <p>
        If you have questions about the booking process or prefer to schedule via phone, 
        you can reach me directly at <a href="tel:+917568592988" class="text-accent underline font-bold">+91 75685 92988</a>.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
