---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";

const terms = await getCollection("glossary");
const sortedTerms = terms.sort((a, b) => a.data.term.localeCompare(b.data.term));
---

<Layout title={`Mental Health Glossary | ${SITE.title}`}>
  <Header activeNav="about" />
  <Main pageTitle="Mental Health Glossary" pageDesc="A plain-English guide to psychological terms and concepts.">
    
    <div class="mt-8 p-6 bg-accent/10 border border-accent/20 rounded-2xl flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
            <h3 class="text-lg font-bold text-accent mb-1">Words of Wisdom</h3>
            <p class="text-sm opacity-80">Explore our collection of 100 mental health quotes with detailed context and reflections.</p>
        </div>
        <a href="/quotes" class="shrink-0 px-6 py-2 bg-accent text-white rounded-full font-bold hover:scale-105 transition-transform text-sm whitespace-nowrap">
            View Quotes
        </a>
    </div>

    <div class="mt-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {sortedTerms.map(item => (
                <a href={`/glossary/${item.id}`} class="group p-6 border border-muted rounded-2xl hover:border-accent hover:shadow-lg transition-all bg-muted/5 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-4">
                            <h2 class="text-xl font-bold text-accent group-hover:underline">{item.data.term}</h2>
                            {item.data.visualAid && (
                                <span class="text-[10px] bg-accent/10 text-accent px-2 py-0.5 rounded-full font-bold uppercase tracking-widest flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                    Visual
                                </span>
                            )}
                        </div>
                        <p class="text-sm opacity-70 line-clamp-3 mb-4">{item.data.description}</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {item.data.tags.map(tag => (
                            <span class="text-[10px] bg-muted px-2 py-1 rounded-full opacity-60 uppercase font-bold tracking-tighter">{tag}</span>
                        ))}
                    </div>
                </a>
            ))}
        </div>
    </div>

  </Main>
  <Footer />
</Layout>
