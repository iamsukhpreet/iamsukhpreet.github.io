---
export interface Props {
  url: string;
  title: string;
  shortname?: string;
}

const { url, title, shortname = "iamsukhpreet" } = Astro.props;
---

<div id="disqus_thread" class="mt-8"></div>

<script is:inline define:vars={{ url, title, shortname }}>
  /**
   * Loads Disqus comments.
   * Handles both initial load and Astro View Transitions.
   */
  function loadDisqus() {
    const d = document;
    const thread = d.getElementById("disqus_thread");

    if (!thread) return;

    window.disqus_config = function () {
      this.page.url = url;
      this.page.identifier = url;
      this.page.title = title;
    };

    if (typeof DISQUS !== "undefined") {
      // If Disqus is already loaded, reset it for the new page
      DISQUS.reset({
        reload: true,
        config: window.disqus_config,
      });
    } else {
      // Otherwise, load the script for the first time
      const s = d.createElement("script");
      s.src = `https://${shortname}.disqus.com/embed.js`;
      s.setAttribute("data-timestamp", +new Date());
      (d.head || d.body).appendChild(s);
    }
  }

  // Initial load
  loadDisqus();

  // Handle Astro View Transitions
  document.addEventListener("astro:page-load", loadDisqus);
</script>

<noscript>
  Please enable JavaScript to view the <a
    href="https://disqus.com/?ref_noscript"
    class="underline underline-offset-4 decoration-dashed hover:decoration-solid"
  >
    comments powered by Disqus.
  </a>
</noscript>
